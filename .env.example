PORT=4100
ONECLAW_APPROVAL_MODE=auto
ONECLAW_QUEUE_MODE=inline
ONECLAW_QUEUE_NAME=oneclaw_tasks
ONECLAW_TASK_STORE=postgres
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/oneclaw
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
ONECLAW_ARTIFACTS_DIR=./artifacts
# Web hosts the browser_worker may visit. Browser apps such as Google Chrome/Safari belong in ONECLAW_DESKTOP_APP_ALLOWLIST.
ONECLAW_BROWSER_ALLOWLIST=https://oneai.network,https://theone-eta.vercel.app,https://x.com,https://github.com
TELEGRAM_BOT_TOKEN=
X_APP_KEY=wSH2iiHM0U8HS9xwh6GYO8dR0
X_APP_SECRET=9y5ZaCm0camzDAbbbo1RY2eBo7B3gk63hfPPVydZANULpaHVkK
X_ACCESS_TOKEN=AAAAAAAAAAAAAAAAAAAAANYI9wEAAAAAMNa3GPVd5Z0jLhzT0DyMt65UjwI%3DvgyTZBslCciZmOyKqC2M8kY7GmbfdXJjDwC1VIy5cGnG1rkGAi
X_ACCESS_SECRET=
ONECLAW_ADMIN_TOKEN=change-me
ONECLAW_X_DRY_RUN=false
X_GROWTH_PUBLISH_ENABLED=false
X_GROWTH_STATE_PATH=./artifacts/x-growth-state.json
X_SELF_USERNAME=
X_SELF_USER_ID=

# GitHub
GITHUB_TOKEN=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
GITHUB_DEFAULT_OWNER=weareoneconnection

# Email: SMTP simple mode
ONECLAW_EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Gmail / Google OAuth mode
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_FROM=

# Outlook / Microsoft OAuth mode
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REFRESH_TOKEN=
OUTLOOK_FROM=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Stripe
STRIPE_SECRET_KEY=
STRIPE_DRY_RUN=true
STRIPE_WEBHOOK_SECRET=

# Vector DB
ONECLAW_VECTOR_PROVIDER=qdrant
ONECLAW_VECTOR_URL=
ONECLAW_VECTOR_API_KEY=
ONECLAW_VECTOR_COLLECTION=theone_memory

ONECLAW_MAX_AUTO_PAYMENT_AMOUNT=0
ONECLAW_MAX_AUTO_DB_WRITE_ROWS=0

# Desktop / local computer control
# Only enable this on a trusted local Mac OneClaw process, not on a cloud host.
ONECLAW_BRIDGE_MODE=desktop
ONECLAW_BRIDGE_ID=maqing-macbook
ONECLAW_BRIDGE_NAME=Ma Qing Mac Desktop Bridge
ONECLAW_DESKTOP_ENABLED=true
# Local browser apps are allowlisted here for desktop.app.open.
ONECLAW_DESKTOP_APP_ALLOWLIST=Google Chrome,Safari,Terminal,Notes,Mail,WeChat,Telegram
ONECLAW_DESKTOP_APP_BLOCKLIST=System Settings,Keychain Access,1Password

# Coding Worker sandbox. Local paths must remain under one of these roots.
ONECLAW_CODE_RUNTIME_TARGET=local_bridge
ONECLAW_CODE_WORKSPACE_ALLOWLIST=
ONECLAW_CODE_MAX_FILES=40
ONECLAW_CODE_MAX_FILE_BYTES=512000
ONECLAW_CODE_MAX_TOTAL_BYTES=4000000
ONECLAW_CODE_TIMEOUT_MS=60000

# Agent Engine (self-hosted coding agent inside code.patch.apply).
# The Anthropic key lives ONLY on this runtime (Railway container or local
# machine) — never on Vercel or OneAI. Leave empty to keep the engine off.
ANTHROPIC_API_KEY=
AGENT_ENGINE_MODEL=claude-sonnet-5
AGENT_ENGINE_MAX_TURNS=50
AGENT_ENGINE_MAX_TOOL_CALLS=200
